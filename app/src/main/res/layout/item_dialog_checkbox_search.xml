<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="@dimen/vs_5">

        <LinearLayout
            android:id="@+id/itemSourceLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_dialog_main"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/vs_10">

            <ImageView
                android:id="@+id/ivSourceCheck"
                android:layout_width="@dimen/vs_20"
                android:layout_height="@dimen/vs_20"
                android:src="@drawable/shape_search_clearall" />

            <TextView
                android:id="@+id/tvSourceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/vs_10"
                android:text="Check Source"
                android:textColor="@color/color_FFFFFF"
                android:textSize="@dimen/ts_20" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>